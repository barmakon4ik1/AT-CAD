#: of programs.at_geometry.bulge_from_center:7
msgid "clockwise=True  -> выбираем отрицательный (CW) sweep (0..-2π)"
msgstr ""

#: of programs.at_geometry.bulge_from_center:9
msgid "(x, y) — начальная точка дуги."
msgstr ""

#: of programs.at_geometry.bulge_from_center:10
